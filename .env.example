# PostgreSQL 数据库配置
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alphagpt

# 数据源模式: solana / astock
DATA_SOURCE_MODE=astock

# A股 Tushare 配置
TUSHARE_TOKEN=your_tushare_token
TUSHARE_API_URL=http://api.tushare.pro
ASTOCK_POOL_TYPE=zz1000
ASTOCK_START_DATE=20200101
ASTOCK_MIN_MARKET_CAP=1000000000

# Solana 配置 (实盘交易时需要)
# BIRDEYE_API_KEY=your_birdeye_api_key
# QUICKNODE_RPC_URL=your_quicknode_rpc_url
# SOLANA_PRIVATE_KEY=your_private_key_base58
# WALLET_ADDRESS=your_wallet_address

# Weights & Biases (可选)
# WANDB_API_KEY=your_wandb_api_key
# WANDB_PROJECT=alphagpt

# PostgreSQL 数据库配置
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=alphagpt

# 数据源模式: solana / astock
DATA_SOURCE_MODE=astock

# A股 Tushare 配置
TUSHARE_TOKEN=your_tushare_token
TUSHARE_API_URL=http://api.tushare.pro
ASTOCK_POOL_TYPE=zz1000
ASTOCK_START_DATE=20200101
ASTOCK_MIN_MARKET_CAP=1000000000

# Solana 配置 (实盘交易时需要)
# BIRDEYE_API_KEY=your_birdeye_api_key
# QUICKNODE_RPC_URL=your_quicknode_rpc_url
# SOLANA_PRIVATE_KEY=your_private_key_base58
# WALLET_ADDRESS=your_wallet_address

# 天勤量化 TianQin (tqsdk) 配置
# TIANQIN_USER=your_tianqin_account
# TIANQIN_PASSWORD=your_tianqin_password
# TIANQIN_ASSET_TYPE=futures
# TIANQIN_TIMEFRAMES=1d,5m,15m
# TIANQIN_FUTURES_EXCHANGES=SHFE,DCE,CZCE,INE,CFFEX,GFEX
# TIANQIN_STOCK_POOL=SSE,SZSE
# TIANQIN_DATA_LENGTH=8000
# TIANQIN_START_DATE=2020-01-01

# DuckDB 本地商品期货数据源
# DUCKDB_PATH=~/quant/tick_data/kline_1min.duckdb
# DUCKDB_PRODUCTS=al,cu,ag,au,rb,i
# DUCKDB_EXCHANGES=
# DUCKDB_TIMEFRAMES=1d,15m

# Weights & Biases (可选)
# WANDB_API_KEY=your_wandb_api_key
# WANDB_PROJECT=alphagpt
